{
  "name": "@618coffee/interactive-globe",
  "version": "0.13.2",
  "description": "Full-screen interactive 3D Earth React component (Three.js): real Blue Marble textures, animated POI markers, LOD geographic labels, glass-morphism UI.",
  "license": "MIT",
  "author": "618coffee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/618coffee/interactive-globe.git",
    "directory": "react"
  },
  "homepage": "https://github.com/618coffee/interactive-globe#readme",
  "bugs": {
    "url": "https://github.com/618coffee/interactive-globe/issues"
  },
  "keywords": [
    "three.js",
    "earth",
    "globe",
    "3d",
    "react",
    "react-component",
    "geography",
    "visualization",
    "webgl"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:example": "vite build",
    "build": "vite build -c vite.lib.config.js && node scripts/copy-types.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "npm run test:ci && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.155"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "d3-geo": "^3.1.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.0",
    "topojson-client": "^3.1.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "world-atlas": "^2.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
